# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.ty/
.claude

# Python packaging and build output
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Coverage and test output
.coverage
.coverage.*
coverage.xml
htmlcov/

# Local environment and editor files
.env
.env.*
!.env.example
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
.worktrees/

# Logs and local databases
*.log
*.sqlite
*.sqlite3
*.db

# Node dependencies and package-manager caches
node_modules/
.npm/
.pnpm-store/
.yarn/
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/sdks/
!.yarn/versions/

# Compiled Wayland layer-shell bridge (built by build_bridge.sh)
src/kotonoha/libkoto-layer*.so

# Cider plugin package-manager output
